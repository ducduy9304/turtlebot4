          <pose>0 -0.9 1.7 0 0 0</pose>
          <geometry><box><size>5.0 0.1 0.02</size></box></geometry>
          <material>
            <ambient>0 0.6 1 1</ambient>
            <diffuse>0 0.6 1 1</diffuse>
            <emissive>0 0.3 0.5 1</emissive>
          </material>
        </visual>
      </link>
    </model>

