<?xml version='1.0' encoding='ASCII'?>
<sdf version='1.7'>
  <world name='restaurant'>
    <physics type="ode">
      <max_step_size>0.003</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin name='ignition::gazebo::systems::Physics' filename='libignition-gazebo-physics-system.so'/>
    <plugin name='ignition::gazebo::systems::UserCommands' filename='libignition-gazebo-user-commands-system.so'/>
    <plugin name='ignition::gazebo::systems::SceneBroadcaster' filename='libignition-gazebo-scene-broadcaster-system.so'/>

    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>true</shadows>
      <grid>false</grid>
    </scene>

    <light name='sun' type='directional'>
      <pose>0 0 10 0 -0 0</pose>
      <cast_shadows>false</cast_shadows>
      <intensity>1</intensity>
      <direction>-0.5 0.1 -0.9</direction>
      <diffuse>1 1 1 1</diffuse>
      <specular>1 1 1 1</specular>
      <attenuation>
        <range>10</range>
        <linear>1</linear>
        <constant>1</constant>
        <quadratic>0</quadratic>
      </attenuation>
    </light>

    <!-- Ground plane with collision so the robot can stand -->
    <model name='ground_plane'>
      <static>true</static>
      <link name='link'>
        <collision name='collision'>
          <geometry>
            <plane>
              <normal>0.0 0.0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name='visual'>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ==================== KITCHEN HUB (inlined from kitchen_hub/model.sdf) ==================== -->
    <model name='kitchen_hub'>
      <static>true</static>
      <pose>0 -8.1 0 0 -0 0</pose>
      <link name="link">
        <!-- Main Base -->
        <visual name="base_visual">
          <pose>0 0 0.5 0 0 0</pose>
          <geometry><box><size>6.0 2.0 1.0</size></box></geometry>
          <material>
            <ambient>1 1 1 1</ambient>
            <diffuse>1 1 1 1</diffuse>
            <specular>0.5 0.5 0.5 1</specular>
          </material>
        </visual>
        <collision name="base_collision">
          <pose>0 0 0.5 0 0 0</pose>
          <geometry><box><size>6.0 2.0 1.0</size></box></geometry>
        </collision>
        <!-- Top Counter -->
        <visual name="top_counter">
          <pose>0 0 1.1 0 0 0</pose>
          <geometry><box><size>6.4 2.4 0.02</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.3 0.3 0.3 1</diffuse>
            <specular>1 1 1 1</specular>
          </material>
        </visual>
        <collision name="top_counter">
          <pose>0 0 1.1 0 0 0</pose>
          <geometry><box><size>6.4 2.4 0.02</size></box></geometry>
        </collision>
        <!-- Back Wall -->
        <visual name="back_wall">
          <pose>0 -1.0 1.5 0 0 0</pose>
          <geometry><box><size>6.0 0.2 1.0</size></box></geometry>
          <material>
            <ambient>0.9 0.9 0.9 1</ambient>
            <diffuse>0.9 0.9 0.9 1</diffuse>
          </material>
        </visual>
